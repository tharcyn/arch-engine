    "capabilityId": { "type": "string" },
    "description": { "type": "string" },
    "evaluationScope": { "type": "string" },
    "mutationClassificationCoverage": {
      "type": "array",
      "items": { "type": "string" }
    },
    "authorityCrossingDetectionBehavior": { "type": "string" },
    "requiredDatasetSchemas": {
      "type": "array",
      "items": { "type": "string" }
