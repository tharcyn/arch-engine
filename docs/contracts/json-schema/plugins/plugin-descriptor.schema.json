{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PluginDescriptor",
  "type": "object",
  "properties": {
    "pluginId": { "type": "string" },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["pluginId", "capabilities"]
}
