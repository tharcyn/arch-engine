{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegistryPolicyPackManifest",
  "type": "object",
  "properties": {
    "policyPackId": { "type": "string" },
    "policyPackVersion": { "type": "string" },
    "supportedCapabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredCapabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supportedDatasetSchemas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supportedExecutionModes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["single-provider", "multi-provider-federated"]
      }
    }
  },
  "required": [
    "policyPackId",
    "policyPackVersion",
    "supportedCapabilities",
    "requiredCapabilities",
    "supportedDatasetSchemas",
    "supportedExecutionModes"
  ],
  "additionalProperties": false
}
