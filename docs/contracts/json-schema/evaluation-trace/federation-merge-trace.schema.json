{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FederationMergeTrace",
  "type": "object",
  "properties": {
    "traceStepId": { "type": "string" },
    "traceType": { "type": "string", "const": "FEDERATION_MERGE" },
    "inputContextHash": { "type": "string" },
    "decisionOutcome": { "type": "string" },
    "decisionReason": { "type": "string" },
