  "title": "IdentityResolutionTrace",
  "type": "object",
  "properties": {
    "traceStepId": { "type": "string" },
    "traceType": { "type": "string", "const": "IDENTITY_RESOLUTION" },
    "inputContextHash": { "type": "string" },
    "decisionOutcome": { "type": "string" },
    "decisionReason": { "type": "string" },
    "nodeId": { "type": "string" },
