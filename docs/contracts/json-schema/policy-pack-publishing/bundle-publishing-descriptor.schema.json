{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BundlePublishingDescriptor",
  "type": "object",
  "properties": {
    "targetRegistryId": { "type": "string" },
    "targetCatalogId": { "type": "string" },
    "publishStrategy": {
      "type": "string",
      "enum": ["append-only", "append-with-version-check", "replace-if-hash-match", "reject-if-exists"]
    },
    "signatureRequirement": {
      "type": "string",
      "enum": ["required", "optional", "none"]
    },
    "promotionStage": {
      "type": "string",
      "enum": ["development", "staging", "verified", "production", "deprecated", "revoked"]
    },
    "mirrorPropagationPolicy": {
      "type": "string",
      "enum": ["propagate-immediately", "propagate-on-promotion", "do-not-propagate"]
    },
    "catalogMutationMode": {
      "type": "string",
      "enum": ["strict-parity", "allow-append"]
    }
  },
  "required": [
    "targetRegistryId",
    "targetCatalogId",
    "publishStrategy",
    "signatureRequirement",
    "promotionStage",
    "mirrorPropagationPolicy",
    "catalogMutationMode"
  ],
  "additionalProperties": false
}
