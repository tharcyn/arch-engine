{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FindingDiagnostic",
  "type": "object",
  "properties": {
    "fileReference": {
      "type": "object",
      "properties": {
        "uri": { "type": "string" },
        "line": { "type": "number" },
        "character": { "type": "number" }
      },
      "required": ["uri", "line", "character"]
    },
    "ruleReference": { "type": "string" },
    "packReference": { "type": "string" },
    "severity": { "type": "string" },
    "traceReferenceId": { "type": "string" },
    "suggestedResolutionHint": { "type": "string" },
    "message": { "type": "string" }
  },
  "required": [
    "fileReference",
    "ruleReference",
    "packReference",
    "severity",
    "traceReferenceId",
    "suggestedResolutionHint",
    "message"
  ]
}
