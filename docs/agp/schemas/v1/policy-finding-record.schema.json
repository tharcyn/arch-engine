{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arch-engine.dev/agp/v1/policy-finding-record.schema.json",
  "title": "AGP v1 — policy_finding record",
  "description": "Factual outcome of policy evaluation. findingId reuses Arch-Engine data.violations[].id when present, otherwise derives deterministically (OQ-2 default). derivedFromObservation declares dependency on non-factual evidence.",

  "type": "object",
  "additionalProperties": false,
  "required": ["family", "kind", "payload"],

  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/RecordSchemaVersion" },
    "family":        { "const": "policy_finding" },
    "kind":          { "$ref": "common.schema.json#/$defs/PolicyFindingKind" },
    "id":            { "$ref": "common.schema.json#/$defs/RecordId" },
    "plane":         { "const": "factual" },
    "payloadHash":   { "$ref": "common.schema.json#/$defs/PayloadHash" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["findingId", "severity", "ciBlocking", "code", "message"],
      "properties": {
        "findingId": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^(v_[0-9a-f]+|agp-finding:[0-9a-f]{8,64})$"
        },
        "severity":   { "$ref": "common.schema.json#/$defs/Severity" },
        "ciBlocking": { "$ref": "common.schema.json#/$defs/CiBlocking" },
        "code":       { "$ref": "common.schema.json#/$defs/DiagnosticCode" },
        "message":    { "type": "string", "minLength": 1 },
        "ruleId":     { "type": "string" },
        "policyPack": { "type": "string" },
        "category":   { "type": "string" },
        "edgeRef":    {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to", "type"],
          "properties": {
            "from": { "type": "string" },
            "to":   { "type": "string" },
            "type": { "type": "string", "enum": ["workspace_dependency"] }
          }
        },
        "affectedRecordIds": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/RecordId" }
        },
        "derivedFromObservation": {
          "description": "True iff the policy decision depended on observation records. Forces evidenceRecordIds to be present.",
          "type": "boolean"
        },
        "evidenceRecordIds": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/RecordId" }
        },
        "details":       { "type": "object" },
        "sourceCommand": { "$ref": "common.schema.json#/$defs/SourceCommand" }
      },
      "allOf": [
        {
          "description": "Observation derivation requires evidenceRecordIds to be set and non-empty.",
          "if":   { "properties": { "derivedFromObservation": { "const": true } }, "required": ["derivedFromObservation"] },
          "then": { "required": ["evidenceRecordIds"], "properties": { "evidenceRecordIds": { "minItems": 1 } } }
        }
      ]
    }
  }
}
