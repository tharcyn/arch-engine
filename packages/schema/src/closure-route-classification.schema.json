{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vendoor.com/schemas/closure-route-classification.json",
  "title": "Closure Route Classification Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "uri",
      "method",
      "classification",
      "reason"
    ],
    "properties": {
      "uri": {
        "type": "string"
      },
      "method": {
        "type": "string"
      },
      "classification": {
        "type": "string",
        "enum": [
          "internal",
          "debug",
          "temporary",
          "public_contract"
        ]
      },
      "reason": {
        "type": "string"
      }
    },
    "additionalProperties": false
  }
}
