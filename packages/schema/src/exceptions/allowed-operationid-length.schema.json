{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vendoor.com/schemas/allowed-operationid-length.json",
  "title": "Allowed OperationId Length Exception Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "operationId",
      "length",
      "reason",
      "permanent_or_temporary"
    ],
    "properties": {
      "operationId": {
        "type": "string"
      },
      "length": {
        "type": "integer"
      },
      "reason": {
        "type": "string"
      },
      "permanent_or_temporary": {
        "type": "string",
        "enum": [
          "PERMANENT",
          "TEMPORARY"
        ]
      }
    },
    "additionalProperties": false
  }
}
