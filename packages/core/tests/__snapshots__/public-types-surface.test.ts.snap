/**
 * Authoritative schema version constants for Arch-Engine policy and adapter payloads.
 * This centralizes schema versioning to prevent drift across provider adapters.
 */
declare const POLICY_PR_PAYLOAD_SCHEMA_VERSION: "policy-pr-payload.v1";

