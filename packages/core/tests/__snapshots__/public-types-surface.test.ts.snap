    projectTopologyForValidation(datasetPath: string): ValidatorTopologyView;
    runValidators(datasetPath: string, validators: readonly TopologyValidator[]): ValidatorRunnerResultEnvelope;
    /**
     * Deterministically evaluate the full reasoning topology pipeline.
     *
     * Freezes the adapter registry, then executes reconciliation,
     * confidence propagation, and topology synthesis in fixed order.
     *
     * Returns immutable snapshots — never live registry references.
     */
    executePipeline(state: EngineExecutionState): Promise<EngineExecutionResult>;
}

