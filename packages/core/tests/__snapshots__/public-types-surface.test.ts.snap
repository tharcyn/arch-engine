        target: string;
        type: string;
    }[];
    authority_boundaries?: Record<string, string[]>;
}
type ImpactSimulationResponse = ReasoningProtocolV1;
declare class ImpactSimulator {
    simulateImpact(request: ImpactSimulationRequest): ImpactSimulationResponse;
}

export { ImpactSimulator };
"
