{
  "name": "@arch-engine/agp-emitter",
  "version": "0.1.0",
  "private": true,
  "description": "Private/experimental AGP canonical bundle emitter. Converts Arch-Engine JSON v2 reports into deterministic agp/snapshot.json + agp/records.ndjson bundles. NOT published to npm; NOT integrated into the main arch-engine CLI.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tharcyn/arch-engine.git",
    "directory": "packages/agp-emitter"
  },
  "homepage": "https://github.com/tharcyn/arch-engine",
  "bugs": {
    "url": "https://github.com/tharcyn/arch-engine/issues"
  },
  "keywords": [
    "agp",
    "evidence",
    "bundle",
    "canonical",
    "deterministic",
    "blake3",
    "rfc8785",
    "arch-engine",
    "private"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agp-emit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist -p tsconfig.json"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
