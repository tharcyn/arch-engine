{
  "name": "@arch-engine/adapter-gitlab",
  "version": "1.0.0",
  "private": true,
  "description": "GitLab provider adapter for Arch-Engine",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arch-engine/core": "*",
    "@arch-engine/adapter-shared": "*",
    "@gitbeaker/rest": "^40.0.0"
  },
  "devDependencies": {
    "@arch-engine/adapter-conformance": "*",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
