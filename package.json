{
  "name": "arch-engine",
  "version": "4.0.0",
  "private": true,
  "description": "Framework-agnostic architecture reasoning engine — topology intelligence, contract parity validation, invariant enforcement, and simulation traversal.",
  "workspaces": [
    "packages/schema",
    "packages/core",
    "packages/cli",
    "packages/governance-pack-rest-contract",
    "packages/governance-pack-authority",
    "packages/governance-pack-journey"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ajv": "^8.18.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
